# Server
NODE_ENV=production
PORT=3000

# Database (PostgreSQL)
# Use DATABASE_URL for Render/Railway/Supabase
DATABASE_URL=postgres://user:password@host:5432/dbname

# Auth (REQUIRED - minimum 32 characters for KEY_SECRET)
KEY_SECRET=your_256_bit_jwt_secret_key_min_32_chars_here
JWT_EXPIRY=15m
REFRESH_SECRET=another_32_character_random_string_here
REFRESH_EXPIRY=7d

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# File Upload
MAX_FILE_SIZE_MB=2
UPLOAD_DIR=uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100