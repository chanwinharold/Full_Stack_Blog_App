# Server
NODE_ENV=production
PORT=3000

# Database (Supabase)
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_USER=postgres
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_PORT=5432

# Auth (REQUIRED - minimum 32 characters for KEY_SECRET)
KEY_SECRET=your_256_bit_jwt_secret_key_min_32_chars_here
JWT_EXPIRY=15m
REFRESH_SECRET=another_32_character_random_string_here
REFRESH_EXPIRY=7d

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-render-app.onrender.com

# File Upload
MAX_FILE_SIZE_MB=2
UPLOAD_DIR=uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100